# ─── Mobile app (Expo) ───────────────────────────────────────────────
# Any var prefixed with EXPO_PUBLIC_ is inlined into the JS bundle at build time.
# DO NOT put server-only secrets here.

# Supabase — get from https://app.supabase.com/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Stripe — test key from https://dashboard.stripe.com/test/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Your deployed Stripe backend (see server/ — defaults to localhost for dev)
EXPO_PUBLIC_BACKEND_URL=http://localhost:4242

# ─── Stripe backend (server/.env) ────────────────────────────────────
# Copy these into server/.env after `cp server/.env.example server/.env`
# STRIPE_SECRET_KEY=sk_test_
# PORT=4242
