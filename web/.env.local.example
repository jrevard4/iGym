# Next.js env vars — copy to web/.env.local

# Same Supabase project as the mobile app (URL + anon key from app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Stripe — test key from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# URL of the deployed Stripe backend (server/index.js)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4242

# Anthropic key for the AI matchmaker — server-only, NOT prefixed with NEXT_PUBLIC_.
# Used by app/api/matchmaker/route.js; never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Public URL of this deployment — used for metadataBase, sitemap.xml, robots.txt.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Platform-operator admin password (/admin) — server-only, NOT prefixed with
# NEXT_PUBLIC_. Checked by app/api/admin-login/route.js; never sent to the browser.
ADMIN_PASSWORD=

# Optional shared secret for app/api/send-class-reminders — set this and pass
# it as the `x-cron-secret` header from whatever scheduler (Vercel Cron, a
# server cron job, etc.) calls that route every 15-30 min. Leave blank to
# allow unauthenticated calls (fine for local dev, not for production).
CRON_SECRET=
