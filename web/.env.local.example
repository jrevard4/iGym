# Next.js env vars — copy to web/.env.local

# Same Supabase project as the mobile app (URL + anon key from app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Stripe — test key from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# URL of the deployed Stripe backend (server/index.js)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4242
