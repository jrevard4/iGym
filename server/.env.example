# Stripe backend env vars (server-only — never on the mobile client)

# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_

# Port to listen on (defaults to 4242)
PORT=4242

# Webhook signing secret — required for recurring membership billing to
# actually renew/expire passes. Get it from `stripe listen` locally, or the
# dashboard endpoint's "Signing secret" once deployed.
# https://stripe.com/docs/webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# Same Supabase project as the mobile/web apps (see ../lib/env.js) — the
# webhook writes subscription renewal/cancellation status directly to the
# `passes` table, so this backend needs its own copy of these.
SUPABASE_URL=
SUPABASE_ANON_KEY=
